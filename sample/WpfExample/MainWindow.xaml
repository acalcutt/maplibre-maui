<Window x:Class="WpfExample.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mlwpf="clr-namespace:MapLibreNative.Maui.WPF;assembly=MapLibreNative.Maui.WPF"
        Title="MapLibre WPF Example" Width="1100" Height="750">

    <DockPanel>

        <!-- ── Toolbar row 1: navigation ── -->
        <ToolBar DockPanel.Dock="Top" Margin="2,2,2,0">

            <Label Content="Fly to:" VerticalAlignment="Center" />
            <Button Content="Seattle"   Click="BtnSeattle_Click"   Margin="2,0" Padding="6,2" />
            <Button Content="London"    Click="BtnLondon_Click"    Margin="2,0" Padding="6,2" />
            <Button Content="New York"  Click="BtnNewYork_Click"   Margin="2,0" Padding="6,2" />

            <Separator Margin="4,0" />

            <Label Content="Camera:" VerticalAlignment="Center" />
            <Button Content="＋" Click="BtnZoomIn_Click"  Margin="2,0" Padding="6,2"
                    ToolTip="Zoom in" />
            <Button Content="－" Click="BtnZoomOut_Click" Margin="2,0" Padding="6,2"
                    ToolTip="Zoom out" />
            <Button Content="⬆ N"   Click="BtnNorth_Click"  Margin="2,0" Padding="6,2"
                    ToolTip="Reset north / pitch" />

            <Separator Margin="4,0" />

            <Label Content="GeoJSON:" VerticalAlignment="Center" />
            <Button x:Name="BtnMarker" Content="Add Marker"
                    Click="BtnMarker_Click" Margin="2,0" Padding="6,2" />

            <Separator Margin="4,0" />

            <Button x:Name="BtnDataDrivenTest" Content="Run Data-Driven Circle Test"
                    Click="BtnDataDrivenTest_Click" Margin="2,0" Padding="6,2"
                    ToolTip="Adds runtime circle layers using literal, property-function (stops), case-expression and match-expression circle-color, then logs how many features render for each — see %TEMP%\maplibre_datadriven_test.log" />

            <Separator Margin="4,0" />

            <!-- GPS overlay simulation -->
            <Label Content="GPS sim:" VerticalAlignment="Center" />
            <Button x:Name="BtnGpsStart" Content="▶ Start"
                    Click="BtnGpsStart_Click" Margin="2,0" Padding="6,2"
                    ToolTip="Start simulated GPS walk through Seattle. Tap ○/⊙/◎ on the map to cycle Off/Show/Follow mode." />
            <Button x:Name="BtnGpsStop" Content="⏹ Stop"
                    Click="BtnGpsStop_Click" Margin="2,0" Padding="6,2"
                    IsEnabled="False"
                    ToolTip="Stop GPS simulation" />

        </ToolBar>

        <!-- ── Toolbar row 2: style picker + custom URL ── -->
        <ToolBar DockPanel.Dock="Top" Margin="2,0,2,2">

            <Label Content="Style:" VerticalAlignment="Center" />
            <ComboBox x:Name="StylePicker" Width="180" Margin="2,0"
                      VerticalAlignment="Center"
                      SelectionChanged="StylePicker_SelectionChanged"
                      ToolTip="Switch to a preset MapLibre style" />

            <Separator Margin="4,0" />

            <Label Content="Custom URL:" VerticalAlignment="Center" />
            <TextBox x:Name="UrlEntry" Width="310" Margin="2,0"
                     VerticalAlignment="Center" VerticalContentAlignment="Center"
                     ToolTip="Paste any MapLibre style URL or JSON and click Apply"
                     KeyDown="UrlEntry_KeyDown" />
            <Button Content="Apply" Click="BtnApplyUrl_Click" Margin="2,0" Padding="6,2"
                    ToolTip="Load the URL in the text box" />

        </ToolBar>

        <!-- ── Status bar ── -->
        <StatusBar DockPanel.Dock="Bottom">
            <StatusBarItem>
                <TextBlock x:Name="StatusText" Text="Initialising…" />
            </StatusBarItem>
        </StatusBar>

        <!-- ── Map ── -->
        <!--
            MlnMapHost is an HwndHost — it owns a child HWND backed by OpenGL.
            StyleUrl, ShowNavigationControls and events are set here; everything
            else (pan, zoom, double-tap) is handled internally by the control.
        -->
        <mlwpf:MlnMapHost x:Name="MapHost"
                           StyleUrl="https://demotiles.maplibre.org/style.json"
                           ShowNavigationControls="True"
                           ShowGpsControl="True"
                           MapReady="MapHost_MapReady"
                           StyleLoaded="MapHost_StyleLoaded"
                           CameraIdle="MapHost_CameraIdle" />
    </DockPanel>

</Window>
