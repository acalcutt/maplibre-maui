<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:maplibre="clr-namespace:Maui.MapLibre.Handlers;assembly=Maui.Maplibre.Handlers"
             xmlns:local="clr-namespace:MauiSample"
             x:DataType="local:BasicMapViewModel"
             x:Class="MauiSample.BasicMapPage"
             Title="Basic Map">

    <Grid RowDefinitions="*, Auto">

        <!-- Map fills the top area -->
        <maplibre:MapLibreMap
            Grid.Row="0"
            x:Name="Map"
            StyleUrl="{Binding StyleUrl}" />

        <!-- Controls bar at the bottom -->
        <VerticalStackLayout Grid.Row="1" Spacing="8" Padding="12">

            <!-- Style picker -->
            <Picker Title="Map Style"
                    ItemsSource="{Binding StyleNames}"
                    SelectedItem="{Binding SelectedStyleName}" />

            <!-- Jump-to city buttons -->
            <Label Text="Jump to city:" FontAttributes="Bold" />
            <FlexLayout Wrap="Wrap" JustifyContent="Start" Gap="8">
                <Button Text="London"   Clicked="OnCityClicked" CommandParameter="London"   />
                <Button Text="New York" Clicked="OnCityClicked" CommandParameter="New York" />
                <Button Text="Tokyo"   Clicked="OnCityClicked" CommandParameter="Tokyo"   />
                <Button Text="Sydney"  Clicked="OnCityClicked" CommandParameter="Sydney"  />
            </FlexLayout>

            <!-- Debug overlay toggle -->
            <HorizontalStackLayout Spacing="8" VerticalOptions="Center">
                <Label Text="Debug Overlays:" FontAttributes="Bold" VerticalOptions="Center" />
                <Switch x:Name="DebugSwitch" Toggled="OnDebugToggled" VerticalOptions="Center" />
            </HorizontalStackLayout>

            <!-- Status line -->
            <Label Text="{Binding Status}" FontSize="12" TextColor="Gray" />

        </VerticalStackLayout>
    </Grid>

</ContentPage>
