<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:maplibre="clr-namespace:Maui.MapLibre.Handlers;assembly=Maui.Maplibre.Handlers"
             x:Class="MauiSample.MarkersPage"
             Title="Markers">

    <Grid RowDefinitions="*,Auto,Auto">
        <maplibre:MapLibreMap x:Name="Map"
                              Grid.Row="0"
                              StyleUrl="{Binding StyleUrl}"
                              MapReady="OnMapReady" />

        <HorizontalStackLayout Grid.Row="1" Spacing="8" Padding="8">
            <Button Text="Add Landmarks"   Clicked="OnAddMarkers" />
            <Button Text="Remove Landmarks" Clicked="OnRemoveMarkers" />
        </HorizontalStackLayout>

        <Label Grid.Row="2" Text="{Binding Status}" Padding="8,4" />
    </Grid>
</ContentPage>
