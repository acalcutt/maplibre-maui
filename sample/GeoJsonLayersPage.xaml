<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:maplibre="clr-namespace:Maui.MapLibre.Handlers;assembly=Maui.Maplibre.Handlers"
             xmlns:local="clr-namespace:MauiSample"
             x:DataType="local:GeoJsonLayersViewModel"
             x:Class="MauiSample.GeoJsonLayersPage"
             Title="GeoJSON Layers">

    <Grid RowDefinitions="*, Auto">

        <maplibre:MapLibreMap
            Grid.Row="0"
            x:Name="Map"
            StyleUrl="{Binding StyleUrl}" />

        <VerticalStackLayout Grid.Row="1" Spacing="8" Padding="12">

            <Label Text="GeoJSON Layers demo — polygon park + walking route" FontAttributes="Bold" />

            <FlexLayout Wrap="Wrap" JustifyContent="Start" Gap="8">
                <Button Text="Add Polygon"    Clicked="OnAddPolygon"    />
                <Button Text="Remove Polygon" Clicked="OnRemovePolygon" />
                <Button Text="Toggle Route"   Clicked="OnToggleRoute"   />
            </FlexLayout>

            <Label Text="{Binding Status}" FontSize="12" TextColor="Gray" />

        </VerticalStackLayout>
    </Grid>

</ContentPage>
